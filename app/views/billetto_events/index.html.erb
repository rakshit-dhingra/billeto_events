<div class="container">
  <h1>Events</h1>
  
  <% if @events.any? %>
    <div class="events-list">
      <% @events.each do |event| %>
        <div class="event-card">
          <h3><%= event.title %></h3>
          <p><%= event.description %></p>
          <p>Location: <%= event.location %></p>
          <p>Starts: <%= event.starts_at %></p>
          <div class="vote-counts">
            <span>👍 <%= event.upvotes %></span>
            <span>👎 <%= event.downvotes %></span>
          </div>
          <%= button_to "Upvote", upvote_billetto_event_path(event), method: :post, class: "btn btn-primary" %>
          <%= button_to "Downvote", downvote_billetto_event_path(event), method: :post, class: "btn btn-danger" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p>No events available.</p>
  <% end %>
</div>
